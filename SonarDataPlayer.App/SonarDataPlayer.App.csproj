<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\SonarDataPlayer.Core\SonarDataPlayer.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\SonarDataPlayer.Core\MatplotlibPalettes.json" Link="MatplotlibPalettes.json">
