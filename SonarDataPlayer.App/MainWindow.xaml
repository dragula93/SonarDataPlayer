<Window x:Class="SonarDataPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonar Data Player v0.4.1"
        Height="860"
        MinHeight="660"
        Width="1280"
        MinWidth="980"
        Background="#101318">
    <Window.Resources>
        <Style x:Key="ViewModeSegmentButton" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="#1F2933" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Segment"
                                Margin="2"
                                CornerRadius="16"
                                Background="#EEF2F7"
                                BorderBrush="#C9D3DF"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Segment" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Segment" Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="Segment" Property="Background" Value="#2E8A57" />
                                <Setter TargetName="Segment" Property="BorderBrush" Value="#5CDC8B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="92" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#171B22" BorderBrush="#242B36" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" Margin="16,0">
                <Button DockPanel.Dock="Left"
                        Width="124"
                        Height="34"
                        Margin="0,0,14,0"
                        Click="OpenManifest_Click"
                        Content="Open Project" />
                <Button DockPanel.Dock="Left"
                        Width="124"
                        Height="34"
                        Margin="0,0,14,0"
                        Click="NewProject_Click"
                        Content="New Project" />
                <Button DockPanel.Dock="Left"
                        Width="88"
                        Height="34"
                        Margin="0,0,14,0"
                        Click="PythonSettings_Click"
                        Content="Python..." />
                <Button x:Name="SaveProjectButton"
                        DockPanel.Dock="Left"
                        Width="112"
                        Height="34"
                        Margin="0,0,14,0"
                        Click="SaveProject_Click"
                        IsEnabled="False"
                        Content="Save Project" />
                <TextBlock x:Name="ProjectStatusText"
                           DockPanel.Dock="Left"
                           Width="150"
                           VerticalAlignment="Center"
                           Foreground="#8E9AAD"
                           Margin="0,0,16,0"
                           Text="" />
                <TextBlock x:Name="RecordingTitle"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#EEF2F7"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="No recording loaded" />
                <TextBlock DockPanel.Dock="Right"
                           Width="72"
                           Text="v0.4.1"
                           Foreground="#8E9AAD"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="104" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#2B3442"
                    BorderThickness="1"
                    Background="#05070A">
                <Grid>
                    <Grid x:Name="ViewerHost"
                          Margin="8"
                          PreviewMouseWheel="ViewerHost_PreviewMouseWheel"
                          SizeChanged="ViewerHost_SizeChanged" />

                    <TextBlock x:Name="EmptyViewerText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#8E9AAD"
                               FontSize="18"
                               Text="Open a processed sonar project manifest to begin playback." />
                </Grid>
            </Border>

                <Grid Grid.Column="1"
                  Margin="10,0,0,0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="12" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="RangeMinLabel"
                               Text="Min"
                               Foreground="#8E9AAD"
                               FontSize="11"
                               Margin="0,0,0,2" />
                    <TextBox x:Name="DepthMinRangeTextBox"
                             Width="76"
                             Height="24"
                             Margin="0,0,0,6"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             PreviewKeyDown="DepthRangeTextBox_KeyDown"
                             LostFocus="DepthRangeTextBox_LostFocus" />

                    <TextBlock x:Name="RangeMaxLabel"
                               Text="Max"
                               Foreground="#8E9AAD"
                               FontSize="11"
                               Margin="0,0,0,2" />
                    <TextBox x:Name="DepthMaxRangeTextBox"
                             Width="76"
                             Height="24"
                             Margin="0,0,0,6"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             PreviewKeyDown="DepthRangeTextBox_KeyDown"
                             LostFocus="DepthRangeTextBox_LostFocus" />

                    <Button x:Name="DepthRangeApplyButton"
                            Width="76"
                            Height="24"
                            Margin="0,0,0,8"
                            Click="DepthRangeApply_Click"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Content="Set Range" />

                    <Button x:Name="DepthZoomInButton"
                        Width="76"
                        Height="48"
                        Click="DepthZoomIn_Click"
                        FontSize="24"
                        FontWeight="Bold"
                        Content="+" />
                    <Button x:Name="DepthZoomAutoButton"
                        Width="76"
                        Height="58"
                        Click="DepthZoomAuto_Click"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Content="Auto" />
                    <Button x:Name="DepthZoomOutButton"
                        Width="76"
                        Height="48"
                        Click="DepthZoomOut_Click"
                        FontSize="24"
                        FontWeight="Bold"
                        Content="-" />
                </StackPanel>

                <ScrollBar x:Name="DepthPanScrollBar"
                       Grid.Column="1"
                       Margin="2,6,0,6"
                       Orientation="Vertical"
                       Minimum="0"
                       Maximum="0"
                       IsEnabled="False"
                       ValueChanged="DepthPanScrollBar_ValueChanged" />
                </Grid>

            <Border Grid.Column="2"
                    Margin="14,0,0,0"
                    Padding="14"
                    BorderBrush="#2B3442"
                    BorderThickness="1"
                    Background="#151A21">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Channels"
                               Foreground="#EEF2F7"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <ItemsControl x:Name="ChannelControls">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="{Binding Label}"
                                              Foreground="#D7DEE8"
                                              IsChecked="{Binding IsVisible}" />
                                    <Slider Grid.Column="1"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="{Binding Opacity}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,12,0,14" Background="#2B3442" />

                    <TextBlock Text="Display"
                               Foreground="#EEF2F7"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <TextBlock Text="Color Scheme"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="PaletteSelector"
                                  Grid.Column="0"
                                  Height="32"
                                  SelectionChanged="PaletteSelector_SelectionChanged"
                                  IsTextSearchEnabled="True" />

                        <CheckBox x:Name="FullPaletteListCheckBox"
                                  Grid.Column="1"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  Foreground="#D7DEE8"
                                  Content="Full list"
                                  Checked="PaletteListVisibilityChanged"
                                  Unchecked="PaletteListVisibilityChanged" />
                    </Grid>

                    <TextBlock Text="Contrast"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="ContrastSelector"
                              Height="32"
                              SelectionChanged="ContrastSelector_SelectionChanged"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="Soft (0.5%-99.9%)" Tag="soft" />
                        <ComboBoxItem Content="Balanced (1%-99.5%)" Tag="balanced" />
                        <ComboBoxItem Content="Strong (2%-99%)" Tag="strong" />
                        <ComboBoxItem Content="Custom" Tag="custom" />
                    </ComboBox>

                        <TextBlock x:Name="ContrastLowClipLabel"
                               Text="Low clip: 1.00%"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                        <Slider x:Name="ContrastLowClipSlider"
                            Height="28"
                            Minimum="0"
                            Maximum="20"
                            ValueChanged="ContrastCustomSlider_ValueChanged"
                            PreviewMouseLeftButtonUp="RenderSettingSlider_PreviewMouseLeftButtonUp"
                            Margin="0,0,0,8" />

                        <TextBlock x:Name="ContrastHighClipLabel"
                               Text="High clip: 99.50%"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                        <Slider x:Name="ContrastHighClipSlider"
                            Height="28"
                            Minimum="80"
                            Maximum="100"
                            ValueChanged="ContrastCustomSlider_ValueChanged"
                            PreviewMouseLeftButtonUp="RenderSettingSlider_PreviewMouseLeftButtonUp"
                            Margin="0,0,0,12" />

                    <CheckBox x:Name="ContrastLockCheckBox"
                              Content="Lock across channels"
                              Foreground="#D7DEE8"
                              Margin="0,0,0,12"
                              Checked="ContrastLockCheckBox_Changed"
                              Unchecked="ContrastLockCheckBox_Changed" />

                        <TextBlock x:Name="SideScanBoostLabel"
                               Text="Side scan boost: 0.60"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                        <Slider x:Name="SideScanBoostSlider"
                            Height="28"
                            Minimum="0"
                            Maximum="2"
                            TickFrequency="0.05"
                            ValueChanged="SideScanBoostSlider_ValueChanged"
                            PreviewMouseLeftButtonUp="RenderSettingSlider_PreviewMouseLeftButtonUp"
                            Margin="0,0,0,12" />

                    <Separator Margin="0,0,0,14" Background="#2B3442" />

                    <TextBlock Text="Units"
                               Foreground="#EEF2F7"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                        <TextBlock Text="Timeline"
                               Foreground="#EEF2F7"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                        <TextBlock Text="Along-Track Stretch"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                        <Slider x:Name="AlongTrackStretchSlider"
                            Height="28"
                            Minimum="1.0"
                            Maximum="4.0"
                            Value="1.0"
                            TickFrequency="0.1"
                            ValueChanged="AlongTrackStretchSlider_ValueChanged" />
                        <TextBlock x:Name="AlongTrackStretchValueText"
                               Foreground="#D7DEE8"
                               Margin="0,2,0,10"
                               Text="1.00x" />

                        <Separator Margin="0,0,0,14" Background="#2B3442" />

                    <TextBlock Text="Depth"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="DepthUnitSelector"
                              Height="32"
                              SelectedIndex="1"
                              SelectionChanged="UnitSelector_SelectionChanged"
                              Margin="0,0,0,10">
                        <ComboBoxItem Content="Feet" Tag="Feet" />
                        <ComboBoxItem Content="Meters" Tag="Meters" />
                        <ComboBoxItem Content="Fathoms" Tag="Fathoms" />
                    </ComboBox>

                    <TextBlock Text="Speed"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="SpeedUnitSelector"
                              Height="32"
                              SelectedIndex="0"
                              SelectionChanged="UnitSelector_SelectionChanged">
                        <ComboBoxItem Content="MPH" Tag="Mph" />
                        <ComboBoxItem Content="Knots" Tag="Knots" />
                    </ComboBox>

                    <TextBlock Text="Water Temp"
                               Foreground="#8E9AAD"
                               Margin="0,10,0,4" />
                    <ComboBox x:Name="TemperatureUnitSelector"
                              Height="32"
                              SelectedIndex="0"
                              SelectionChanged="UnitSelector_SelectionChanged">
                        <ComboBoxItem Content="Celsius" Tag="Celsius" />
                        <ComboBoxItem Content="Fahrenheit" Tag="Fahrenheit" />
                    </ComboBox>

                    <TextBlock Text="UTC Offset"
                               Foreground="#8E9AAD"
                               Margin="0,10,0,4" />
                    <ComboBox x:Name="UtcOffsetSelector"
                              Height="32"
                              SelectedIndex="1"
                              SelectionChanged="UnitSelector_SelectionChanged">
                        <ComboBoxItem Content="UTC-5" Tag="-5" />
                        <ComboBoxItem Content="UTC-4 DST" Tag="-4" />
                        <ComboBoxItem Content="UTC" Tag="0" />
                    </ComboBox>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#171B22" BorderBrush="#242B36" BorderThickness="0,1">
            <Grid Margin="16,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="34" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <Button x:Name="PlayPauseButton"
                        Grid.Row="0"
                        Width="72"
                        Height="34"
                        Click="PlayPause_Click"
                        Content="Play" />
                <Slider x:Name="SeekSlider"
                        Grid.Row="0"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        ValueChanged="SeekSlider_ValueChanged"
                        Margin="10,0" />
                <ComboBox x:Name="ZoomSelector"
                          Grid.Row="0"
                          Grid.Column="2"
                          Height="32"
                          SelectedIndex="0"
                          SelectionChanged="ZoomSelector_SelectionChanged">
                    <ComboBoxItem Content="Full" Tag="0" />
                    <ComboBoxItem Content="+/- 120s" Tag="240" />
                    <ComboBoxItem Content="+/- 60s" Tag="120" />
                    <ComboBoxItem Content="+/- 30s" Tag="60" />
                    <ComboBoxItem Content="+/- 10s" Tag="20" />
                </ComboBox>
                <ComboBox x:Name="RateSelector"
                          Grid.Row="0"
                          Grid.Column="3"
                          Height="32"
                          SelectedIndex="2"
                          SelectionChanged="RateSelector_SelectionChanged">
                    <ComboBoxItem Content="0.25x" Tag="0.25" />
                    <ComboBoxItem Content="0.5x" Tag="0.5" />
                    <ComboBoxItem Content="1x" Tag="1" />
                    <ComboBoxItem Content="2x" Tag="2" />
                    <ComboBoxItem Content="4x" Tag="4" />
                </ComboBox>
                <TextBlock x:Name="TimeReadout"
                           Grid.Row="0"
                           Grid.Column="4"
                           VerticalAlignment="Center"
                           Foreground="#D7DEE8"
                           TextAlignment="Right"
                           Text="0.0 / 0.0 s" />

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Width="390"
                        Height="34"
                        HorizontalAlignment="Center"
                        Background="#D7DEE8"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid Margin="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="StackedMode"
                                     Grid.Column="0"
                                     GroupName="ViewMode"
                                     Style="{StaticResource ViewModeSegmentButton}"
                                     Content="Stacked"
                                     IsChecked="True"
                                     Checked="ViewMode_Checked" />
                        <RadioButton x:Name="OverlayMode"
                                     Grid.Column="1"
                                     GroupName="ViewMode"
                                     Style="{StaticResource ViewModeSegmentButton}"
                                     Content="Overlay"
                                     Checked="ViewMode_Checked" />
                        <RadioButton x:Name="SideScanMode"
                                     Grid.Column="2"
                                     GroupName="ViewMode"
                                     Style="{StaticResource ViewModeSegmentButton}"
                                     Content="Side Scan"
                                     Checked="ViewMode_Checked" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock x:Name="DepthReadout"
                           Foreground="#EEF2F7"
                           FontSize="22"
                           FontWeight="Bold"
                           Text="Depth: -" />
                <TextBlock x:Name="TempReadout"
                           Foreground="#D7DEE8"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Text="Water Temp: -" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="SpeedReadout"
                           Foreground="#EEF2F7"
                           FontSize="22"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Text="Speed: -" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Grid Width="74"
                      Height="74"
                      HorizontalAlignment="Center">
                    <Ellipse Width="64"
                             Height="64"
                             Fill="#0B0F14"
                             Stroke="#5B6778"
                             StrokeThickness="1.5"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <TextBlock Text="N"
                               Foreground="#EEF2F7"
                               FontSize="11"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,7,0,0" />
                    <TextBlock Text="S"
                               Foreground="#8E9AAD"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,7" />
                    <TextBlock Text="W"
                               Foreground="#8E9AAD"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                    <TextBlock Text="E"
                               Foreground="#8E9AAD"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Polygon Points="37,13 42,39 37,34 32,39"
                             Fill="#FFEF84"
                             Stroke="#101318"
                             StrokeThickness="0.6"
                             RenderTransformOrigin="0.5,0.5">
                        <Polygon.RenderTransform>
                            <RotateTransform x:Name="HeadingNeedleTransform"
                                             Angle="0" />
                        </Polygon.RenderTransform>
                    </Polygon>
                    <Ellipse Width="7"
                             Height="7"
                             Fill="#EEF2F7"
                             Stroke="#101318"
                             StrokeThickness="1"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
                <TextBlock x:Name="HeadingDegreesReadout"
                           Foreground="#EEF2F7"
                           FontSize="15"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,-3,0,0"
                           Text="- deg" />
            </StackPanel>

            <TextBlock x:Name="PositionReadout"
                       Grid.Row="1"
                       Grid.ColumnSpan="3"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Foreground="#EEF2F7"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Text="Position: -" />
        </Grid>
    </Grid>
</Window>
